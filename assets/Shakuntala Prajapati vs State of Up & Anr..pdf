    <main style="width: 54%; margin-left: 215px;">
      <h2 style="margin-left: 300px;">Legal Library</h2>
        <div class="search-bar">
            <input type="text" id="search-input" placeholder="Search for pre-judges cases by name or genre">
            <button id="search-button"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg></button>
        </div>
        <!-- ... (previous HTML code) ... -->

<!-- Dynamic Heading -->
<div id="dynamic-heading" class="dynamic-heading">
    <!-- The content of the heading will be updated dynamically -->
</div>

</div>
        
        <div class="book-list">
            <!-- Books will be dynamically added here -->
        </div>
        <!-- Loader -->
        <div id="loader" class="loader"></div>
        <div id="disapear-div">
          <h3>Know your basic rights as an Indian citizen</h3>
          <div id="rights-list">
          </div>
        </div>
    </main>
    <div id="book-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <img id="book-image" src="" alt="Book Image">
            <div class="modal-buttons">
                <button id="download-button">Download</button>
                <button id="close-modal-button">Close</button>
            </div>
        </div>
    </div>

    <aside class="side-nav right-sidebar">
        <script type='module' src='https://interfaces.zapier.com/assets/web-components/zapier-interfaces/zapier-interfaces.esm.js'></script>
        <zapier-interfaces-page-embed page-id='cln2vi4od452340qlc6ltg4uci' no-background='false' style='max-width: 100%; height: 100%;'></zapier-interfaces-page-embed>
    </aside>

    <div id="book-preview-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Book Title</h2>
            <div class="book-preview">
                <canvas id="pdf-canvas"></canvas>
            </div>
            <button id="download-button">Download</button>
        </div>
    </div>

    <script src="script.js"></script>
